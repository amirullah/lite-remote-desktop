<Application x:Class="RemoteDesktop.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- ============ palette (clean blue) ============ -->
        <Color x:Key="AccentColor">#2F7CF6</Color>
        <Color x:Key="Accent2Color">#4EA1FF</Color>
        <SolidColorBrush x:Key="Bg" Color="#0A1220"/>
        <SolidColorBrush x:Key="Panel" Color="#111C30"/>
        <SolidColorBrush x:Key="PanelHi" Color="#1A2A47"/>
        <SolidColorBrush x:Key="Stroke" Color="#22335A"/>
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="Fg" Color="#EAF1FB"/>
        <SolidColorBrush x:Key="Muted" Color="#7E90AE"/>
        <SolidColorBrush x:Key="Good" Color="#2FBF71"/>
        <SolidColorBrush x:Key="Bad" Color="#E5534B"/>
        <!-- secondary-button + disabled surfaces (themed live by ThemeManager) -->
        <SolidColorBrush x:Key="GhostBg" Color="#0F1B30"/>
        <SolidColorBrush x:Key="GhostBorder" Color="#33507F"/>
        <SolidColorBrush x:Key="DisabledBg" Color="#26344F"/>
        <SolidColorBrush x:Key="DisabledBorder" Color="#33456A"/>
        <SolidColorBrush x:Key="DisabledFg" Color="#6E7E9C"/>

        <LinearGradientBrush x:Key="AccentGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
            <GradientStop Color="{StaticResource Accent2Color}" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AppBg" StartPoint="0,0" EndPoint="0.6,1">
            <GradientStop Color="#0D1930" Offset="0"/>
            <GradientStop Color="#080E1B" Offset="1"/>
        </LinearGradientBrush>

        <!-- ============ text ============ -->
        <!-- NOTE: no Foreground here. An implicit TextBlock Foreground bleeds into ContentPresenter-
             generated button text and OVERRIDES the button's own Foreground (so a white-labelled button
             would render its text in Fg — dark, invisible, in light mode). The default text colour is set
             once at each Window root (Foreground="{DynamicResource Fg}") and INHERITED instead, so buttons
             keep their white text and plain TextBlocks still follow the theme. -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <!-- Display snaps glyph advances to whole device pixels — crisp small UI text.
                 Ideal (the old value) uses fractional print metrics that look soft at 11-14px. -->
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- ============ primary button (high-contrast, crisp edge + glow) ============ -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource AccentGrad}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="9"
                                    BorderBrush="#59FFFFFF" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0A1220" BlurRadius="12" ShadowDepth="1.5" Opacity="0.45"/>
                                </Border.Effect>
                            </Border>
                            <!-- lighten on hover / darken on press — works for any Background colour -->
                            <Border x:Name="ov" CornerRadius="9" Background="Transparent"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ov" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#99FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ov" Property="Background" Value="#38000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledBg}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource DisabledBorder}"/>
                                <Setter TargetName="b" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- destructive button (Disconnect / Putus) — same crisp template, red fill -->
        <Style x:Key="Danger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource Bad}"/>
        </Style>

        <!-- secondary button — FILLED with a muted surface + WHITE text (distinct from the bright
             primary, but uniformly white-labelled). Lighten on hover / darken on press. -->
        <Style x:Key="Ghost" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource GhostBg}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"/>
                            <Border x:Name="ov" CornerRadius="8" Background="Transparent"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ov" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ov" Property="Background" Value="#33000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- subtle list-item / card button (the Recent list) — readable body text on a soft surface,
             NOT a filled action button, so the session name stays legible. -->
        <Style x:Key="Card" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource Bg}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{DynamicResource Stroke}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource PanelHi}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ inputs ============ -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="8"
                                BorderBrush="{DynamicResource Stroke}" BorderThickness="1" Padding="10,8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="8"
                                BorderBrush="{DynamicResource Stroke}" BorderThickness="1" Padding="10,8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fully-templated dark ComboBox: the WPF default renders a white chrome dropdown that is
             unreadable on this theme, so every visual part is replaced. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="10,8" Margin="4,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource PanelHi}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentGrad}"/>
                                <!-- WHITE on the blue highlight — Fg would be dark (invisible) in light theme. -->
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{DynamicResource Bg}" CornerRadius="8"
                                                BorderBrush="{DynamicResource Stroke}" BorderThickness="1">
                                            <Path Data="M0,0 L4.5,4.5 9,0" Stroke="{DynamicResource Muted}" StrokeThickness="1.6"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,2,14,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="12,0,32,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" PopupAnimation="Fade" StaysOpen="False">
                                <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Stroke}"
                                        BorderThickness="1" CornerRadius="10" Margin="0,6,0,0" Padding="0,4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        </Style>

        <!-- segmented toggle (RadioButton styled as a pill tab) -->
        <Style x:Key="Segment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="7" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentGrad}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,0,0,5"/>
        </Style>
    </Application.Resources>
</Application>
