<Window x:Class="RemoteDesktop.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:RemoteDesktop.Client.Services"
        Title="{loc:Loc Connect.WindowTitle}" Height="760" Width="1120"
        Icon="/Assets/literemote.ico"
        Background="{DynamicResource AppBg}" WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable, Segoe UI"
        TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display">

    <Grid>
        <!-- ================= CONNECT PANEL ================= -->
        <Grid x:Name="ConnectPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>
            <!-- soft accent glow in the corner -->
            <Ellipse Grid.Column="0" Width="520" Height="520" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-180,-160,0" Opacity="0.20" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#2F7CF6" Offset="0"/>
                        <GradientStop Color="#002F7CF6" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ===== right column: Recent / saved sessions (all types, one-click reconnect) ===== -->
            <Border Grid.Column="1" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Stroke}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Loc Connect.RecentHeader}" Style="{StaticResource Label}" Margin="18,20,0,10"/>
                    <TextBlock x:Name="RecentEmpty" DockPanel.Dock="Top" Visibility="Collapsed"
                               Text="{loc:Loc Connect.RecentEmpty}"
                               Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="18,0,16,8" FontSize="12"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentList" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Button Style="{StaticResource Ghost}" Padding="10,9" HorizontalContentAlignment="Stretch"
                                                Tag="{Binding}" Click="RecentCard_Click" ToolTip="{loc:Loc Connect.RecentReconnectTip}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border CornerRadius="4" Padding="6,1" Margin="0,0,8,0" Background="{DynamicResource Accent}">
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0">
                                            <Button Style="{StaticResource Ghost}" Content="✎" Padding="7,2" FontSize="11"
                                                    Tag="{Binding}" Click="RecentEdit_Click" ToolTip="{loc:Loc Connect.RecentEditTip}"/>
                                            <Button Style="{StaticResource Ghost}" Content="✕" Padding="7,2" FontSize="11" Margin="4,0,0,0"
                                                    Tag="{Binding}" Click="RecentDelete_Click" ToolTip="{loc:Loc Connect.RecentDeleteTip}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,10">
                <StackPanel Width="470" Margin="0,28,0,28">

                    <!-- brand + theme/language pickers -->
                    <DockPanel Margin="2,0,0,22">
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                            <ComboBox x:Name="ThemeBox" Width="140" Height="34" SelectionChanged="Theme_Changed"
                                      ToolTip="{loc:Loc Settings.ThemeTip}">
                                <ComboBoxItem Content="{loc:Loc Settings.Theme.System}"/>
                                <ComboBoxItem Content="{loc:Loc Settings.Theme.Light}"/>
                                <ComboBoxItem Content="{loc:Loc Settings.Theme.Dark}"/>
                            </ComboBox>
                            <ComboBox x:Name="LangBox" Width="140" Height="34" Margin="0,8,0,0" SelectionChanged="Language_Changed"
                                      ToolTip="{loc:Loc Settings.LangTip}">
                                <ComboBoxItem Content="Indonesia"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource AccentGrad}">
                                <TextBlock Text="◆" FontSize="20" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc Connect.WindowTitle}" FontSize="24" FontWeight="Bold"/>
                                <TextBlock Text="{loc:Loc Connect.Tagline}"
                                           Foreground="{DynamicResource Muted}" FontSize="12.5"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <!-- main card. The drop shadow lives on an EMPTY sibling border behind the content,
                         NOT on the content border — an Effect renders its whole subtree through a bitmap,
                         which turns ClearType off and blurs every label/input/button inside. -->
                    <Grid>
                    <Border CornerRadius="18" Background="{DynamicResource Panel}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="{DynamicResource Panel}" CornerRadius="18" Padding="22"
                            BorderBrush="{DynamicResource Stroke}" BorderThickness="1">
                        <StackPanel>

                            <!-- connection type: pick first, the form below adapts -->
                            <TextBlock Text="{loc:Loc Connect.TypeLabel}" Style="{StaticResource Label}" Margin="2,0,0,5"/>
                            <Border Background="{DynamicResource Bg}" CornerRadius="10" Padding="4"
                                    BorderBrush="{DynamicResource Stroke}" BorderThickness="1">
                                <UniformGrid Rows="1" Columns="3">
                                    <RadioButton x:Name="ModeAddrRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="{loc:Loc Connect.TypeAddr}" IsChecked="True" Checked="Mode_Changed"
                                                 ToolTip="{loc:Loc Connect.TypeAddrTip}"/>
                                    <RadioButton x:Name="ModeIdRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="{loc:Loc Connect.TypeId}" Checked="Mode_Changed"
                                                 ToolTip="{loc:Loc Connect.TypeIdTip}"/>
                                    <RadioButton x:Name="ModeRdpRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="{loc:Loc Connect.TypeRdp}" Checked="Mode_Changed"
                                                 ToolTip="{loc:Loc Connect.TypeRdpTip}"/>
                                </UniformGrid>
                            </Border>

                            <!-- optional display name (same field as the edit dialog) -->
                            <TextBlock Text="{loc:Loc Connect.NameLabel}" Style="{StaticResource Label}" Margin="2,18,0,5"/>
                            <TextBox x:Name="NameBox"/>

                            <!-- ID mode -->
                            <StackPanel x:Name="IdModePanel" Margin="0,18,0,0" Visibility="Collapsed">
                                <TextBlock Text="{loc:Loc Connect.PartnerIdLabel}" Style="{StaticResource Label}"/>
                                <TextBox x:Name="IdBox" FontSize="22" FontWeight="SemiBold"
                                         Padding="12,10" Text=""/>
                                <TextBlock Text="{loc:Loc Connect.PartnerIdHint}"
                                           Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="2,6,0,0"/>
                            </StackPanel>

                            <!-- address mode (host + port; saved sessions live in the Recent column) -->
                            <StackPanel x:Name="AddrModePanel" Margin="0,18,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Connect.HostAddressLabel}" Style="{StaticResource Label}"/>
                                        <TextBox x:Name="HostBox" Text="192.168.1.10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{loc:Loc Connect.PortLabel}" Style="{StaticResource Label}"/>
                                        <TextBox x:Name="PortBox" Text="7443"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- credentials (LiteRemote protocol: by address or ID) -->
                            <StackPanel x:Name="LoginSection">
                                <TextBlock Text="{loc:Loc Connect.SignInWith}" Style="{StaticResource Label}" Margin="2,18,0,5"/>
                                <Border Background="{DynamicResource Bg}" CornerRadius="10" Padding="4"
                                        BorderBrush="{DynamicResource Stroke}" BorderThickness="1">
                                    <UniformGrid Rows="1" Columns="2">
                                        <RadioButton x:Name="AuthPasswordRadio" GroupName="auth" Style="{StaticResource Segment}"
                                                     Content="{loc:Loc Connect.AuthPassword}" IsChecked="True" Checked="AuthMethod_Changed"/>
                                        <RadioButton x:Name="AuthGoogleRadio" GroupName="auth" Style="{StaticResource Segment}"
                                                     Content="{loc:Loc Connect.AuthGoogle}" Checked="AuthMethod_Changed"/>
                                    </UniformGrid>
                                </Border>

                                <StackPanel x:Name="PasswordArea" Margin="0,14,0,0">
                                    <TextBlock Text="{loc:Loc Connect.HostPasswordLabel}" Style="{StaticResource Label}"/>
                                    <PasswordBox x:Name="PasswordBox"/>
                                    <CheckBox x:Name="SavePasswordCheck" Margin="1,8,0,0"
                                              Content="{loc:Loc Connect.RememberPassword}"
                                              ToolTip="{loc:Loc Connect.RememberPasswordTip}"/>
                                    <TextBlock Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="2,6,0,0" TextWrapping="Wrap"
                                               Text="{loc:Loc Connect.HostPasswordHint}"/>
                                </StackPanel>
                                <StackPanel x:Name="GoogleArea" Margin="0,12,0,0" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Loc Connect.GoogleClientIdLabel}" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="GoogleClientIdBox"/>
                                    <TextBlock Text="{loc:Loc Connect.GoogleHint}"
                                               Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="2,6,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- RDP credentials (Windows RDP type) — fill here once, connect directly -->
                            <StackPanel x:Name="RdpCredPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                <TextBlock Text="{loc:Loc Connect.RdpUserLabel}" Style="{StaticResource Label}" Margin="2,14,0,5"/>
                                <TextBox x:Name="RdpUserBox"/>
                                <TextBlock Text="{loc:Loc Connect.RdpPasswordLabel}" Style="{StaticResource Label}" Margin="2,12,0,5"/>
                                <PasswordBox x:Name="RdpPassBox"/>
                                <CheckBox x:Name="RdpSaveCheck" Margin="1,8,0,0"
                                          Content="{loc:Loc Connect.RdpRemember}"
                                          ToolTip="{loc:Loc Connect.RdpRememberTip}"/>
                                <TextBlock Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="2,6,0,0" TextWrapping="Wrap"
                                           Text="{loc:Loc Connect.RdpCredHint}"/>
                            </StackPanel>

                            <!-- optional VPN (address &amp; RDP only — ID goes through the relay) -->
                            <StackPanel x:Name="VpnToggleSection" Margin="0,16,0,0">
                                <CheckBox x:Name="UseVpnCheck" Click="UseVpn_Changed"
                                          Content="{loc:Loc Connect.UseVpn}"
                                          ToolTip="{loc:Loc Connect.UseVpnTip}"/>
                                <StackPanel x:Name="VpnArea" Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Loc Connect.OvpnProfileLabel}" Style="{StaticResource Label}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="VpnProfileBox" Grid.Column="0" IsReadOnly="True" Text=""/>
                                        <Button Grid.Column="1" Content="{loc:Loc Common.Pick}" Style="{StaticResource Ghost}" Margin="8,0,0,0" Click="BrowseVpn_Click"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{loc:Loc Connect.VpnUserLabel}" Style="{StaticResource Label}"/>
                                            <TextBox x:Name="VpnUserBox"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{loc:Loc Connect.VpnPasswordLabel}" Style="{StaticResource Label}"/>
                                            <PasswordBox x:Name="VpnPassBox"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- Advanced — adapts to the connection type; sits right above Connect -->
                            <Expander x:Name="AdvancedExpander" Header="{loc:Loc Connect.AdvancedHeader}" Foreground="{DynamicResource Muted}" Margin="0,16,0,0">
                                <Border Background="{DynamicResource Bg}" CornerRadius="12" Padding="16" Margin="0,10,0,0"
                                        BorderBrush="{DynamicResource Stroke}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel x:Name="AdvRelay" Visibility="Collapsed">
                                            <TextBlock Text="{loc:Loc Connect.RelayLabel}" Style="{StaticResource Label}"/>
                                            <TextBox x:Name="RelayBox" Text=""/>
                                            <TextBlock Text="{loc:Loc Connect.RelayHint}"
                                                       Foreground="{DynamicResource Muted}" FontSize="11" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <StackPanel x:Name="AdvProtocolOpts" Visibility="Collapsed">
                                            <TextBlock Text="{loc:Loc Connect.SessionOpts}" Style="{StaticResource Label}" Margin="2,12,0,6"/>
                                            <WrapPanel>
                                                <CheckBox x:Name="ClipboardCheck" Content="{loc:Loc Connect.SyncClipboard}" IsChecked="True" Margin="0,0,18,8"/>
                                                <CheckBox x:Name="BlankScreenCheck" Content="{loc:Loc Connect.BlankScreen}" Margin="0,0,18,8"/>
                                                <CheckBox x:Name="LockInputCheck" Content="{loc:Loc Connect.LockInput}" Margin="0,0,0,8"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- connect (label adapts to the chosen type) -->
                            <Button x:Name="ConnectButton" FontSize="15"
                                    Padding="16,12" Margin="0,18,0,0" Click="Connect_Click"/>
                            <TextBlock x:Name="StatusText" Foreground="{DynamicResource Muted}"
                                       TextWrapping="Wrap" Margin="2,10,0,0" MinHeight="16"/>
                        </StackPanel>
                    </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
