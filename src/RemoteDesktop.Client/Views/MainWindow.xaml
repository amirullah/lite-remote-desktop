<Window x:Class="RemoteDesktop.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiteRemote" Height="760" Width="1120"
        Icon="/Assets/literemote.ico"
        Background="{StaticResource AppBg}" WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable, Segoe UI"
        TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display">

    <Grid>
        <!-- ================= CONNECT PANEL ================= -->
        <Grid x:Name="ConnectPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>
            <!-- soft accent glow in the corner -->
            <Ellipse Grid.Column="0" Width="520" Height="520" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-180,-160,0" Opacity="0.20" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#2F7CF6" Offset="0"/>
                        <GradientStop Color="#002F7CF6" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ===== right column: Recent / saved sessions (all types, one-click reconnect) ===== -->
            <Border Grid.Column="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Stroke}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="RECENT &amp; SAVED" Style="{StaticResource Label}" Margin="18,20,0,10"/>
                    <TextBlock x:Name="RecentEmpty" DockPanel.Dock="Top" Visibility="Collapsed"
                               Text="Belum ada sesi tersimpan. Konek sekali — sesinya muncul di sini untuk sambung ulang 1-klik."
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="18,0,16,8" FontSize="12"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentList" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Button Style="{StaticResource Ghost}" Padding="10,9" HorizontalContentAlignment="Stretch"
                                                Tag="{Binding}" Click="RecentCard_Click" ToolTip="Sambungkan ulang">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border CornerRadius="4" Padding="6,1" Margin="0,0,8,0" Background="{StaticResource Accent}">
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource Ghost}" Content="✕" Padding="7,2" FontSize="11"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,6,0"
                                                Tag="{Binding}" Click="RecentDelete_Click" ToolTip="Hapus dari daftar"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,10">
                <StackPanel Width="470" Margin="0,28,0,28">

                    <!-- brand -->
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,22">
                        <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource AccentGrad}">
                            <TextBlock Text="◆" FontSize="20" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="LiteRemote" FontSize="24" FontWeight="Bold"/>
                            <TextBlock Text="Fast · lightweight · secure remote desktop"
                                       Foreground="{StaticResource Muted}" FontSize="12.5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- main card. The drop shadow lives on an EMPTY sibling border behind the content,
                         NOT on the content border — an Effect renders its whole subtree through a bitmap,
                         which turns ClearType off and blurs every label/input/button inside. -->
                    <Grid>
                    <Border CornerRadius="18" Background="{StaticResource Panel}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="{StaticResource Panel}" CornerRadius="18" Padding="22"
                            BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                        <StackPanel>

                            <!-- connection type: pick first, the form below adapts -->
                            <TextBlock Text="JENIS KONEKSI" Style="{StaticResource Label}" Margin="2,0,0,5"/>
                            <Border Background="{StaticResource Bg}" CornerRadius="10" Padding="4"
                                    BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                                <UniformGrid Rows="1" Columns="3">
                                    <RadioButton x:Name="ModeAddrRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="LiteRemote · alamat" IsChecked="True" Checked="Mode_Changed"
                                                 ToolTip="Protokol LiteRemote langsung ke alamat IP / host (port 7443)."/>
                                    <RadioButton x:Name="ModeIdRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="LiteRemote · ID" Checked="Mode_Changed"
                                                 ToolTip="Protokol LiteRemote lewat ID 9-digit (butuh relay)."/>
                                    <RadioButton x:Name="ModeRdpRadio" GroupName="mode" Style="{StaticResource Segment}"
                                                 Content="Windows RDP" Checked="Mode_Changed"
                                                 ToolTip="Remote Desktop Windows tertanam (login user+password Windows, bisa menembus layar login). Perlu RDP aktif di PC tujuan (port 3389)."/>
                                </UniformGrid>
                            </Border>

                            <!-- ID mode -->
                            <StackPanel x:Name="IdModePanel" Margin="0,18,0,0" Visibility="Collapsed">
                                <TextBlock Text="PARTNER ID" Style="{StaticResource Label}"/>
                                <TextBox x:Name="IdBox" FontSize="22" FontWeight="SemiBold"
                                         Padding="12,10" Text=""/>
                                <TextBlock Text="Enter the 9-digit ID shown on the remote computer."
                                           Foreground="{StaticResource Muted}" FontSize="11.5" Margin="2,6,0,0"/>
                            </StackPanel>

                            <!-- address mode (host + port; saved sessions live in the Recent column) -->
                            <StackPanel x:Name="AddrModePanel" Margin="0,18,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="HOST ADDRESS" Style="{StaticResource Label}"/>
                                        <TextBox x:Name="HostBox" Text="192.168.1.10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="PORT" Style="{StaticResource Label}"/>
                                        <TextBox x:Name="PortBox" Text="7443"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- credentials (LiteRemote protocol only; RDP logs in inside its own window) -->
                            <StackPanel x:Name="LoginSection">
                                <TextBlock Text="SIGN IN WITH" Style="{StaticResource Label}" Margin="2,18,0,5"/>
                                <Border Background="{StaticResource Bg}" CornerRadius="10" Padding="4"
                                        BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                                    <UniformGrid Rows="1" Columns="2">
                                        <RadioButton x:Name="AuthPasswordRadio" GroupName="auth" Style="{StaticResource Segment}"
                                                     Content="Password" IsChecked="True" Checked="AuthMethod_Changed"/>
                                        <RadioButton x:Name="AuthGoogleRadio" GroupName="auth" Style="{StaticResource Segment}"
                                                     Content="Google account" Checked="AuthMethod_Changed"/>
                                    </UniformGrid>
                                </Border>

                                <StackPanel x:Name="PasswordArea" Margin="0,14,0,0">
                                    <TextBlock Text="HOST ACCESS PASSWORD" Style="{StaticResource Label}"/>
                                    <PasswordBox x:Name="PasswordBox"/>
                                    <CheckBox x:Name="SavePasswordCheck" Margin="1,8,0,0"
                                              Content="Ingat password (DPAPI — akun Windows ini) untuk sambung 1-klik"
                                              ToolTip="Menyimpan password terenkripsi agar sesi ini bisa disambung ulang dari daftar Recent tanpa mengetik lagi."/>
                                    <TextBlock Foreground="{StaticResource Muted}" FontSize="11.5" Margin="2,6,0,0" TextWrapping="Wrap"
                                               Text="The password created on the remote computer: LiteRemote Host tray icon → “Set access password”."/>
                                </StackPanel>
                                <StackPanel x:Name="GoogleArea" Margin="0,12,0,0" Visibility="Collapsed">
                                    <TextBlock Text="GOOGLE OAUTH CLIENT ID" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="GoogleClientIdBox"/>
                                    <TextBlock Text="A browser window will open to sign you in."
                                               Foreground="{StaticResource Muted}" FontSize="11.5" Margin="2,6,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- RDP credentials (shown only for the Windows RDP type) — fill here once and
                                 connect directly; no second login form in the RDP window. -->
                            <StackPanel x:Name="RdpCredPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                <TextBlock Text="WINDOWS USERNAME" Style="{StaticResource Label}" Margin="2,14,0,5"/>
                                <TextBox x:Name="RdpUserBox"/>
                                <TextBlock Text="WINDOWS PASSWORD" Style="{StaticResource Label}" Margin="2,12,0,5"/>
                                <PasswordBox x:Name="RdpPassBox"/>
                                <CheckBox x:Name="RdpSaveCheck" Margin="1,8,0,0"
                                          Content="Ingat user &amp; password (DPAPI) untuk sambung 1-klik"
                                          ToolTip="Menyimpan kredensial Windows terenkripsi agar RDP ini bisa disambung ulang dari Recent tanpa mengetik lagi."/>
                                <TextBlock Foreground="{StaticResource Muted}" FontSize="11.5" Margin="2,6,0,0" TextWrapping="Wrap"
                                           Text="Login akun Windows PC tujuan. RDP bisa menembus layar login. Kosongkan password untuk memasukkannya di layar RDP. VPN (bila perlu) diatur di Advanced."/>
                            </StackPanel>

                            <!-- connect (label adapts to the chosen type) -->
                            <Button x:Name="ConnectButton" Content="Connect" FontSize="15"
                                    Padding="16,12" Margin="0,20,0,0" Click="Connect_Click"/>
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource Muted}"
                                       TextWrapping="Wrap" Margin="2,10,0,0" MinHeight="16"/>
                        </StackPanel>
                    </Border>
                    </Grid>

                    <!-- advanced -->
                    <Expander x:Name="AdvancedExpander" Header="Advanced — performance, display, VPN &amp; relay"
                              Foreground="{StaticResource Muted}" Margin="4,16,0,0">
                        <Border Background="{StaticResource Panel}" CornerRadius="16" Padding="20" Margin="0,10,0,0"
                                BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="RELAY SERVER (for ID connections)" Style="{StaticResource Label}"/>
                                <TextBox x:Name="RelayBox" Text=""/>
                                <TextBlock Text="e.g. relay.example.com:7500 — same server the host registers with."
                                           Foreground="{StaticResource Muted}" FontSize="11" Margin="2,5,0,0"/>

                                <!-- FPS, resolution & quality live in the session toolbar only (applied
                                     live), so there is exactly one place to control them. -->

                                <TextBlock Text="NETWORK PATH" Style="{StaticResource Label}" Margin="2,16,0,5"/>
                                <ComboBox x:Name="NetworkModeBox" SelectedIndex="0" SelectionChanged="NetworkMode_Changed">
                                    <ComboBoxItem>Direct internet / LAN</ComboBoxItem>
                                    <ComboBoxItem>Through VPN profile (this app only)</ComboBoxItem>
                                </ComboBox>
                                <StackPanel x:Name="VpnArea" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                                    <TextBox x:Name="VpnProfileBox" Width="300" IsReadOnly="True" Text="(no .ovpn profile selected)"/>
                                    <Button Content="Browse…" Style="{StaticResource Ghost}" Margin="8,0,0,0" Click="BrowseVpn_Click"/>
                                </StackPanel>

                                <WrapPanel Margin="0,16,0,0">
                                    <CheckBox x:Name="ClipboardCheck" Content="Sync clipboard" IsChecked="True" Margin="0,0,18,8"/>
                                    <CheckBox x:Name="BlankScreenCheck" Content="Blank host screen" Margin="0,0,18,8"/>
                                    <CheckBox x:Name="LockInputCheck" Content="Lock host keyboard/mouse" Margin="0,0,0,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
