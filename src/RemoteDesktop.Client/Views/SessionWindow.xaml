<Window x:Class="RemoteDesktop.Client.Views.SessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiteRemote — sesi" Height="760" Width="1120"
        Icon="/Assets/literemote.ico"
        Background="#05060A" WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable, Segoe UI"
        TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Display">

    <Grid>
        <Grid x:Name="SessionPanel" Background="#05060A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="SessionToolbar" Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Stroke}"
                    BorderThickness="0,0,0,1" Padding="12,8">
                <DockPanel LastChildFill="False">
                    <Border DockPanel.Dock="Left" Width="9" Height="9" CornerRadius="5"
                            Background="{StaticResource Good}" VerticalAlignment="Center" Margin="2,0,10,0"/>
                    <TextBlock x:Name="MonitorLabel" DockPanel.Dock="Left" Text="Monitor" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="Layar fisik di PC host yang ditampilkan (bila host punya beberapa monitor). Angka = resolusi asli monitor itu."/>
                    <ComboBox x:Name="DisplayBox" Width="150" DockPanel.Dock="Left" SelectionChanged="Display_Changed"
                              ToolTip="Pilih monitor host yang ingin dilihat."/>

                    <TextBlock DockPanel.Dock="Left" Text="FPS" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <ComboBox x:Name="SessionFpsBox" Width="100" DockPanel.Dock="Left" SelectedIndex="0"
                              SelectionChanged="SessionFps_Changed">
                        <ComboBoxItem>Auto</ComboBoxItem>
                        <ComboBoxItem>15</ComboBoxItem>
                        <ComboBoxItem>24</ComboBoxItem>
                        <ComboBoxItem>30</ComboBoxItem>
                        <ComboBoxItem>45</ComboBoxItem>
                        <ComboBoxItem>60</ComboBoxItem>
                        <ComboBoxItem>75</ComboBoxItem>
                        <ComboBoxItem>90</ComboBoxItem>
                        <ComboBoxItem>120</ComboBoxItem>
                        <ComboBoxItem>144</ComboBoxItem>
                    </ComboBox>

                    <TextBlock DockPanel.Dock="Left" Text="Res" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="16,0,6,0"
                               ToolTip="Perkecil ukuran stream untuk hemat data / koneksi lambat. 'Default' = resolusi asli (paling tajam). Nilai lebih kecil = lebih ringan tapi kurang tajam."/>
                    <ComboBox x:Name="SessionResBox" Width="130" DockPanel.Dock="Left" SelectedIndex="0"
                              SelectionChanged="SessionRes_Changed"
                              ToolTip="Default = tajam (resolusi asli host). Pilih lebih kecil hanya bila koneksi lambat.">
                        <ComboBoxItem>Default</ComboBoxItem>
                        <ComboBoxItem>4K (3840×2160)</ComboBoxItem>
                        <ComboBoxItem>2560×1600</ComboBoxItem>
                        <ComboBoxItem>2560×1440</ComboBoxItem>
                        <ComboBoxItem>1920×1080</ComboBoxItem>
                        <ComboBoxItem>1680×1050</ComboBoxItem>
                        <ComboBoxItem>1366×768</ComboBoxItem>
                        <ComboBoxItem>1280×1024</ComboBoxItem>
                        <ComboBoxItem>1280×800</ComboBoxItem>
                        <ComboBoxItem>1280×720</ComboBoxItem>
                        <ComboBoxItem>1024×768</ComboBoxItem>
                    </ComboBox>

                    <TextBlock DockPanel.Dock="Left" Text="Codec" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <ComboBox x:Name="SessionCodecBox" Width="150" DockPanel.Dock="Left" SelectedIndex="0"
                              SelectionChanged="SessionCodec_Changed"
                              ToolTip="Otomatis: H.264 hardware bila didukung (PC fisik), selain itu JPEG. JPEG: paling kompatibel.">
                        <ComboBoxItem>Otomatis</ComboBoxItem>
                        <ComboBoxItem>H.264 (hemat data)</ComboBoxItem>
                        <ComboBoxItem>JPEG (kompatibel)</ComboBoxItem>
                    </ComboBox>

                    <TextBlock DockPanel.Dock="Left" Text="Kualitas" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="16,0,6,0"
                               ToolTip="Ketajaman gambar. Lebih tinggi = lebih jernih tapi lebih banyak data. Otomatis menyesuaikan bandwidth."/>
                    <ComboBox x:Name="SessionQualityBox" Width="130" DockPanel.Dock="Left" SelectedIndex="0"
                              SelectionChanged="SessionQuality_Changed"
                              ToolTip="Ketajaman gambar. Lebih tinggi = lebih jernih tapi lebih banyak data.">
                        <ComboBoxItem>Otomatis</ComboBoxItem>
                        <ComboBoxItem>Maksimum</ComboBoxItem>
                        <ComboBoxItem>Tinggi</ComboBoxItem>
                        <ComboBoxItem>Normal</ComboBoxItem>
                        <ComboBoxItem>Hemat data</ComboBoxItem>
                    </ComboBox>

                    <Button Content="Ctrl+Alt+Del" Style="{StaticResource Ghost}" DockPanel.Dock="Left" Margin="16,0,0,0" Click="Cad_Click"/>
                    <Button Content="Fullscreen" Style="{StaticResource Ghost}" DockPanel.Dock="Left" Margin="8,0,0,0" Click="Fullscreen_Click"/>

                    <Button Content="Disconnect" DockPanel.Dock="Right" Background="{StaticResource Bad}" Click="Disconnect_Click"/>
                    <TextBlock x:Name="StatText" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,16,0"
                               Foreground="{StaticResource Muted}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Text="—"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" x:Name="SurfaceHost" Background="#05060A" ClipToBounds="True">
                <Image x:Name="RemoteImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
            </Grid>
        </Grid>

        <!-- connecting / status overlay: covers the surface until the first frame arrives -->
        <Border x:Name="Overlay" Background="#CC05060A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
                <TextBlock Text="◆" FontSize="34" Foreground="{StaticResource Accent}"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock x:Name="OverlayTitle" Text="Menghubungkan…" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="OverlayStatus" Foreground="{StaticResource Muted}" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,10,0,0" MinHeight="18"/>
                <Button x:Name="OverlayClose" Content="Tutup" Style="{StaticResource Ghost}" Visibility="Collapsed"
                        HorizontalAlignment="Center" Margin="0,18,0,0" Padding="16,8" Click="OverlayClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
