<Window x:Class="RemoteDesktop.Client.Views.RdpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="LiteRemote — Windows RDP" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen" Background="#0B1B34">
    <DockPanel>
        <!-- Credential + VPN bar -->
        <Border DockPanel.Dock="Top" Background="#122A4D" Padding="10,8">
            <StackPanel>
                <!-- VPN row (optional): bring a tunnel up first, then RDP -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="VPN (.ovpn)" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="2,0,6,0" FontWeight="SemiBold"/>
                    <TextBox   Grid.Column="1" x:Name="VpnBox" VerticalContentAlignment="Center" Padding="6,4"
                               ToolTip="Opsional. Jika diisi dan host belum terjangkau, LiteRemote membuka profil ini di OpenVPN Connect, menunggu tunnel siap, lalu menyambung RDP otomatis."/>
                    <Button Grid.Column="2" x:Name="PickVpnBtn" Content="Pilih…" Margin="8,0,0,0" Padding="12,4"
                            Background="#33507F" Foreground="White" BorderThickness="0" Click="PickVpn_Click"/>
                    <Button Grid.Column="3" x:Name="ClearVpnBtn" Content="✕" Margin="6,0,0,0" Padding="9,4"
                            Background="#33507F" Foreground="White" BorderThickness="0" Click="ClearVpn_Click" ToolTip="Kosongkan profil VPN (koneksi langsung)"/>
                </Grid>
                <!-- Credential row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Host" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="2,0,6,0" FontWeight="SemiBold"/>
                    <TextBox   Grid.Column="1" x:Name="HostBox" VerticalContentAlignment="Center" Padding="6,4" MinWidth="150"/>
                    <TextBlock Grid.Column="2" Text="User" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="12,0,6,0" FontWeight="SemiBold"/>
                    <TextBox   Grid.Column="3" x:Name="UserBox" VerticalContentAlignment="Center" Padding="6,4"/>
                    <TextBlock Grid.Column="4" Text="Password" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="12,0,6,0" FontWeight="SemiBold"/>
                    <PasswordBox Grid.Column="5" x:Name="PassBox" VerticalContentAlignment="Center" Padding="6,4"/>
                    <Button Grid.Column="6" x:Name="ConnectBtn" Content="Hubungkan" Margin="12,0,0,0" Padding="16,5"
                            Background="#2D7DF6" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Click="Connect_Click"/>
                    <Button Grid.Column="7" x:Name="DisconnectBtn" Content="Putus" Margin="8,0,0,0" Padding="14,5"
                            Background="#33507F" Foreground="White" BorderThickness="0" Click="Disconnect_Click" IsEnabled="False"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status strip -->
        <Border DockPanel.Dock="Bottom" Background="#0E294A" Padding="10,4">
            <TextBlock x:Name="StatusText" Foreground="#B9D2F5" Text="Isi kredensial Windows lalu tekan Hubungkan."/>
        </Border>

        <!-- The embedded RDP ActiveX control lives here -->
        <Border x:Name="RdpFrame" Background="Black">
            <wfi:WindowsFormsHost x:Name="FormsHost"/>
        </Border>
    </DockPanel>
</Window>
