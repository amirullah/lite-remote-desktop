<Window x:Class="RemoteDesktop.Client.Views.RdpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="LiteRemote — Windows RDP" Height="820" Width="1240"
        WindowStartupLocation="CenterScreen" Background="#0B1B34"
        Icon="/Assets/literemote.ico" KeyDown="Window_KeyDown">
    <DockPanel>
        <!-- ===== Top bar: connect fields + session actions (hidden in fullscreen) ===== -->
        <Border x:Name="TopBar" DockPanel.Dock="Top" Background="#122A4D" Padding="12,9">
            <StackPanel>
                <!-- Hero connect row: Host is the star; User/Password inline; actions on the right. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Host" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="2,0,8,0" FontWeight="SemiBold"/>
                    <TextBox   Grid.Column="1" x:Name="HostBox" VerticalContentAlignment="Center" Padding="8,6" FontSize="14" MinWidth="180" LostFocus="HostBox_LostFocus"
                               ToolTip="Alamat / IP komputer tujuan (mis. 192.168.1.10 atau host:3389). RDP harus aktif di sana."/>
                    <TextBlock Grid.Column="2" Text="User" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="14,0,6,0" FontWeight="SemiBold"/>
                    <TextBox   Grid.Column="3" x:Name="UserBox" VerticalContentAlignment="Center" Padding="6,5"/>
                    <TextBlock Grid.Column="4" Text="Password" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="14,0,6,0" FontWeight="SemiBold"/>
                    <PasswordBox Grid.Column="5" x:Name="PassBox" VerticalContentAlignment="Center" Padding="6,5"/>
                    <CheckBox  Grid.Column="6" x:Name="SaveCredsCheck" Content="Simpan sandi" Foreground="#9FC0F0"
                               VerticalAlignment="Center" Margin="14,0,2,0"
                               ToolTip="Simpan password (dienkripsi DPAPI Windows) agar tak perlu diketik lagi."/>
                    <Button Grid.Column="7" x:Name="ConnectBtn" Content="Hubungkan" Margin="14,0,0,0" Padding="18,6"
                            Background="#2D7DF6" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Click="Connect_Click"/>
                    <Button Grid.Column="8" x:Name="DisconnectBtn" Content="Putus" Margin="8,0,0,0" Padding="14,6"
                            Background="#33507F" Foreground="White" BorderThickness="0" Click="Disconnect_Click" IsEnabled="False"/>
                    <Button Grid.Column="9" x:Name="FullscreenBtn" Content="⛶" Margin="8,0,0,0" Padding="11,6" FontSize="14"
                            Background="#33507F" Foreground="White" BorderThickness="0" Click="Fullscreen_Click"
                            ToolTip="Layar penuh (F11 / Esc untuk keluar)"/>
                </Grid>

                <!-- VPN is OPTIONAL and collapsed by default, so direct RDP needs zero extra fields.
                     Expand only when the host is reachable only through an OpenVPN tunnel. -->
                <Expander x:Name="VpnExpander" Header="VPN (opsional) — hanya jika host di balik OpenVPN"
                          Foreground="#9FC0F0" Margin="2,8,0,0" FontSize="12">
                    <Grid Margin="0,8,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Profil .ovpn" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="2,0,6,0"/>
                        <TextBox   Grid.Column="1" x:Name="VpnBox" VerticalContentAlignment="Center" Padding="6,4" TextChanged="VpnBox_TextChanged"
                                   ToolTip="LiteRemote menyalakan tunnel HANYA untuk host di atas (split-tunnel), lalu menyambung RDP otomatis. Perlu izin admin (UAC) sekali saat menyalakan VPN."/>
                        <Button Grid.Column="2" x:Name="PickVpnBtn" Content="Pilih…" Margin="8,0,0,0" Padding="12,4"
                                Background="#33507F" Foreground="White" BorderThickness="0" Click="PickVpn_Click"/>
                        <Button Grid.Column="3" x:Name="ClearVpnBtn" Content="✕" Margin="6,0,0,0" Padding="9,4"
                                Background="#33507F" Foreground="White" BorderThickness="0" Click="ClearVpn_Click" ToolTip="Kosongkan profil VPN"/>
                        <TextBlock Grid.Column="4" Text="VPN user" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="14,0,6,0"/>
                        <TextBox   Grid.Column="5" x:Name="VpnUserBox" VerticalContentAlignment="Center" Padding="6,4"/>
                        <TextBlock Grid.Column="6" Text="VPN pass" Foreground="#9FC0F0" VerticalAlignment="Center" Margin="14,0,6,0"/>
                        <PasswordBox Grid.Column="7" x:Name="VpnPassBox" VerticalContentAlignment="Center" Padding="6,4"/>
                    </Grid>
                </Expander>
            </StackPanel>
        </Border>

        <!-- ===== Status strip ===== -->
        <Border DockPanel.Dock="Bottom" Background="#0E294A" Padding="12,4">
            <TextBlock x:Name="StatusText" Foreground="#B9D2F5" Text="Isi Host + User + Password Windows, lalu tekan Hubungkan. (VPN hanya bila host di balik OpenVPN.)"/>
        </Border>

        <!-- ===== The embedded RDP session ===== -->
        <Border x:Name="RdpFrame" Background="Black">
            <wfi:WindowsFormsHost x:Name="FormsHost"/>
        </Border>
    </DockPanel>
</Window>
